    {
      "id": "9WtDMUWS_wANnWOTG15fC",
      "type": "text",
      "x": 1611.4211080968355,
      "y": 9666.350303428473,
      "width": 702.4422178463436,
      "height": 271.98403893273803,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
