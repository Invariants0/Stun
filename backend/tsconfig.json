{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "tests/types"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "tests/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
